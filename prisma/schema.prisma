datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  CUSTOMER
  SUPPORT_AGENT
  ADMIN
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum Status {
  OPEN
  IN_PROGRESS
  WAITING_FOR_CUSTOMER
  RESOLVED
  CLOSED
}

model User {
  id           String   @id @default(uuid()) @db.Uuid
  name         String
  email        String   @unique
  passwordHash String   @map("password_hash")
  role         Role     @default(CUSTOMER)
  avatarUrl    String?  @map("avatar_url")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  ticketsCreated  Ticket[]        @relation("CustomerTickets")
  ticketsAssigned Ticket[]        @relation("AgentTickets")
  comments        TicketComment[]
  notifications   Notification[]
  statusChanges   StatusHistory[]
  attachments     Attachment[]

  @@index([email])
  @@index([role, isActive])
  @@index([name])
  @@map("users")
}

model Category {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @unique
  description String?
  tickets     Ticket[]

  @@map("categories")
}

model Ticket {
  id              String    @id @default(uuid()) @db.Uuid
  ticketNumber    String    @unique @map("ticket_number")
  customerId      String    @map("customer_id") @db.Uuid
  assignedAgentId String?   @map("assigned_agent_id") @db.Uuid
  subject         String
  description     String
  priority        Priority  @default(MEDIUM)
  status          Status    @default(OPEN)
  categoryId      String    @map("category_id") @db.Uuid
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  closedAt        DateTime? @map("closed_at")

  customer      User            @relation("CustomerTickets", fields: [customerId], references: [id], onDelete: Cascade)
  agent         User?           @relation("AgentTickets", fields: [assignedAgentId], references: [id], onDelete: SetNull)
  category      Category        @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  comments      TicketComment[]
  attachments   Attachment[]
  statusHistory StatusHistory[]

  @@index([customerId, createdAt])
  @@index([assignedAgentId, createdAt])
  @@index([status, createdAt])
  @@index([priority, createdAt])
  @@index([categoryId, createdAt])
  @@index([createdAt])
  @@map("tickets")
}

model TicketComment {
  id         String   @id @default(uuid()) @db.Uuid
  ticketId   String   @map("ticket_id") @db.Uuid
  authorId   String   @map("author_id") @db.Uuid
  message    String
  isInternal Boolean  @default(false) @map("is_internal")
  createdAt  DateTime @default(now()) @map("created_at")

  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  author User   @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([ticketId, createdAt])
  @@map("ticket_comments")
}

model Attachment {
  id         String   @id @default(uuid()) @db.Uuid
  ticketId   String   @map("ticket_id") @db.Uuid
  fileUrl    String   @map("file_url")
  fileName   String   @map("file_name")
  uploadedBy String   @map("uploaded_by") @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at")

  ticket   Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  uploader User   @relation(fields: [uploadedBy], references: [id], onDelete: Cascade)

  @@index([ticketId])
  @@map("attachments")
}

model StatusHistory {
  id          String   @id @default(uuid()) @db.Uuid
  ticketId    String   @map("ticket_id") @db.Uuid
  changedById String   @map("changed_by_id") @db.Uuid
  oldStatus   Status   @map("old_status")
  newStatus   Status   @map("new_status")
  createdAt   DateTime @default(now()) @map("created_at")

  ticket    Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  changedBy User   @relation(fields: [changedById], references: [id], onDelete: Cascade)

  @@index([ticketId, createdAt])
  @@map("status_histories")
}

model Notification {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  message   String
  type      String
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead, createdAt])
  @@index([userId, createdAt])
  @@map("notifications")
}
